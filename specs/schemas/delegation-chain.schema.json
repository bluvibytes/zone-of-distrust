{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bluvi.ai/schemas/zod/delegation-chain.schema.json",
  "title": "ZoD Delegation Chain",
  "type": "object",
  "additionalProperties": false,
  "required": ["chain_id", "links"],
  "properties": {
    "chain_id": { "type": "string", "minLength": 8 },
    "links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "from_agent_id", "to_agent_id", "timestamp", "link_hash"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "from_agent_id": { "type": "string", "minLength": 3 },
          "to_agent_id": { "type": "string", "minLength": 3 },
          "timestamp": { "type": "string", "format": "date-time" },
          "request_summary_digest": {
            "type": "string",
            "description": "Digest of the delegated request summary/canonical form."
          },
          "link_hash": {
            "type": "string",
            "description": "Hash chaining this link to previous links (chain-of-custody)."
          }
        }
      }
    }
  }
}
